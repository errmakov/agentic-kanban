# ── Merge strategy for the append-only feature registry ─────────────────────────
# features/registry.ts is the ONE shared file every feature appends to (an import
# line + an array entry). Parallel features therefore edit the same two anchor
# regions, which would normally conflict when their PRs merge in the same batch.
#
# `merge=union` is git's built-in union merge driver: when both sides change the
# same hunk, keep BOTH sides' lines (concatenated) instead of raising a conflict.
# That is exactly right for an append-only list — every feature's registration is
# preserved, order is irrelevant (FeatureSlot sorts by `order`), and deploy never
# stalls on a registry conflict again.
#
# NOTE: this driver only applies to LOCAL git merges. GitHub's "Squash & merge"
# ignores .gitattributes, so agent-deploy.yml merges PR branches locally (git merge)
# rather than via `gh pr merge --squash`.
features/registry.ts merge=union
