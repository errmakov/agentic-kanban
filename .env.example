# =============================================================================
# Agentic Kanban — Environment Variables
# =============================================================================
# Copy this file to .env for local testing.
# In production, these are set as GitHub repository secrets.
# =============================================================================

# Anthropic API key (from console.anthropic.com)
# Required for all agent workflows
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Personal Access Token with scopes: project, repo, workflow
# Required for project board operations and workflow dispatching
PROJECT_PAT=ghp_...

# GitHub Project configuration
# Find PROJECT_NUMBER at: https://github.com/orgs/YOUR_ORG/projects/N or https://github.com/users/YOUR_USER/projects/N
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo-name
PROJECT_NUMBER=1

# Telegram Bot configuration (for human review notifications)
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Deployment — VPS via Docker Compose (the GitHub Action drives it; contro.lol pattern)
# Set these as GitHub repository *variables* (Settings -> Secrets and variables -> Actions -> Variables):
PRODUCTION_URL=https://factorywall.your-domain.tld
VPS_HOST=your.vps.host
VPS_USERNAME=deploy
VPS_PORT=22
DEPLOY_PATH=/opt/factorywall
FACTORYWALL_EXTERNAL_PORT=3000

# Set this as a GitHub repository *secret* (private SSH key with access to the VPS):
VPS_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----...

# GHCR push uses the built-in GITHUB_TOKEN (no extra secret needed) as long as the
# repo has Packages: write permission, which the deploy workflows request.

# =============================================================================
# FactoryWall app
# =============================================================================
# Optional venue map link shown in the footer. Inlined at build time
# (NEXT_PUBLIC_* vars are exposed to the client bundle).
NEXT_PUBLIC_VENUE_MAP_URL=https://maps.example.com/venue
